{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@localflow/sdk": ["packages/localflow-sdk/src/index.ts"],
      "@localflow/sdk/react": ["packages/localflow-sdk/src/react.ts"],
      "@localflow/sdk/adapters/tauri": ["packages/localflow-sdk/src/adapters/tauri.ts"]
    },
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src", "packages"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
