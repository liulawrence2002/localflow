{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LocalFlow",
  "version": "0.1.0",
  "identifier": "app.localflow.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LocalFlow",
        "width": 1120,
        "height": 760,
        "minWidth": 860,
        "minHeight": 620,
        "visible": false
      },
      {
        "label": "overlay",
        "title": "LocalFlow Voice",
        "url": "index.html?view=overlay",
        "width": 280,
        "height": 96,
        "minWidth": 280,
        "minHeight": 96,
        "maxWidth": 280,
        "maxHeight": 96,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "focusable": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../.localflow-runtime/whisper/Release/whisper-cli.exe": "localflow-runtime/whisper/Release/whisper-cli.exe",
      "../.localflow-runtime/whisper/Release/*.dll": "localflow-runtime/whisper/Release/",
      "../.localflow-runtime/models/ggml-tiny.en-q5_1.bin": "localflow-runtime/models/ggml-tiny.en-q5_1.bin"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
